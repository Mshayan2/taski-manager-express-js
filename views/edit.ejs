<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Edit</title>
</head>
    <body class="min-h-screen bg-gradient-to-br from-zinc-900 via-slate-900 to-zinc-800 text-white">
        
       <div class="main w-full min-h-screen p-4 md:p-8 text-center backdrop-blur-sm">
        
        <div class="form mt-8 max-w-2xl mx-auto">

            <form action="/edit" method="post" class="shadow-2xl rounded-xl bg-zinc-800/50 p-6 transform hover:-translate-y-1 transition-all">
                <input type="text" placeholder="Previse name of file" name="Previse" value="<%= filename %> " disabled="true"
                 class="block w-full outline-none px-4 py-3 bg-zinc-700/50 rounded-lg mb-4 text-white backdrop-blur-md focus:ring-2 focus:ring-blue-500 transition-all">
                <input type="text" placeholder=" New name of file" name="New" class="block w-full outline-none px-4 py-3 bg-zinc-700/50 rounded-lg mb-4 text-white backdrop-blur-md focus:ring-2 focus:ring-blue-500 transition-all">
                <button type="submit" class="bg-gradient-to-r from-blue-500 to-purple-600 text-white px-6 py-3 rounded-lg hover:shadow-lg hover:shadow-blue-500/50 transform hover:-translate-y-1 transition-all ">Change Name</button>
    
            </form>
        </div>


    </body>

</html>