<!-- index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="stylesheet" href="./stylesheet/styles.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Home Page</title>
</head>
<body class="bg-gradient-to-br from-gray-900 to-black">
    <div class="main w-full min-h-screen p-4 md:p-8 text-center backdrop-blur-sm">
        <h1 class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-600 transform hover:scale-105 transition-transform">Task Manager</h1>
        
        <div class="form mt-8 max-w-2xl mx-auto">
            <form action="/create" method="post" class="shadow-2xl rounded-xl bg-zinc-800/50 p-6 transform hover:-translate-y-1 transition-all">
                <input type="text" placeholder="Title goes here" name="title" class="block w-full outline-none px-4 py-3 bg-zinc-700/50 rounded-lg mb-4 text-white backdrop-blur-md focus:ring-2 focus:ring-blue-500 transition-all">
                <textarea placeholder="Write Your Task Details Here..." name="details" class="block w-full h-32 resize-none outline-none px-4 py-3 bg-zinc-700/50 rounded-lg mb-4 text-white backdrop-blur-md focus:ring-2 focus:ring-blue-500 transition-all"></textarea>
                <button type="submit" class="bg-gradient-to-r from-blue-500 to-purple-600 text-white px-6 py-3 rounded-lg hover:shadow-lg hover:shadow-blue-500/50 transform hover:-translate-y-1 transition-all">Create Task</button>
            </form>
        </div>

        <h2 class="text-2xl font-semibold mt-10 mb-6 text-white">Your Tasks</h2>

        <div class="tasks grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
            <% if(files.length > 0 ){ %>
                <% files.forEach(function(val){ %>
                    <div class="task bg-zinc-800/50 backdrop-blur-md p-6 rounded-xl shadow-xl transform hover:-translate-y-2 transition-all hover:shadow-blue-500/20">
                        <h1 class="text-white text-2xl tracking-wider uppercase mb-4"><%= val.split('.')[0] %></h1>
                        <a href="/files/<%= val %>" class="text-blue-400 hover:text-blue-300 transition-colors">Read More →</a>
                         <br>
                        <a href="/edit/<%= val %>" class="text-blue-400 hover:text-blue-300 transition-colors"> Edit </a>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full">
                    <h2 class="text-2xl text-gray-400 bg-zinc-800/50 rounded-xl p-8">No Tasks Yet...</h2>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
